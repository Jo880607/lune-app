rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // users: 본인만 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // records: 본인만 읽기/쓰기
    match /records/{recordId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // analyses: 인증된 유저는 읽기 가능, 본인만 쓰기
    match /analyses/{analysisId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // connections: 인증된 유저는 읽기/생성/수정 가능
    match /connections/{connectionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;

      // messages: 연결 참여자만 읽기/쓰기/삭제 (subcollection)
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          (request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user1Id ||
           request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user2Id);
        allow create: if request.auth != null &&
          (request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user1Id ||
           request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user2Id);
        allow delete: if request.auth != null &&
          (request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user1Id ||
           request.auth.uid == get(/databases/$(database)/documents/connections/$(connectionId)).data.user2Id);
      }
    }

    // conversations: 보관된 대화 (참여자만 읽기/쓰기)
    match /conversations/{conversationId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.user1Id ||
         request.auth.uid == resource.data.user2Id);
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.user1Id ||
         request.auth.uid == request.resource.data.user2Id);
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.user1Id ||
         request.auth.uid == resource.data.user2Id);
    }

    // waitlist: 전화번호 기반 공개 접근 (비인증 유저용)
    match /waitlist/{phone} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // stats: 공개 읽기, 인증된 유저만 쓰기
    match /stats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // admin: 모두 거부 (서버사이드로만 접근)
    match /admin/{document=**} {
      allow read, write: if false;
    }
  }
}
